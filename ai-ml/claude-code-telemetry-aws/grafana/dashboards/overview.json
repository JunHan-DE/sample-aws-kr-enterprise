{
  "uid": "claude-code-overview",
  "title": "Claude Code - Overview",
  "description": "Executive summary combining Prometheus real-time metrics and Athena event-level analysis.",
  "tags": ["claude-code", "overview"],
  "timezone": "utc",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 1,
  "time": {"from": "now-24h", "to": "now"},
  "links": [
    {"title": "Real-Time Metrics", "url": "/d/claude-code-realtime", "type": "link", "icon": "lightning", "tooltip": "All 8 Prometheus metrics in detail"},
    {"title": "Cost Analysis", "url": "/d/claude-code-cost", "type": "link", "icon": "database", "tooltip": "Per-request cost, model efficiency"},
    {"title": "Usage Insights", "url": "/d/claude-code-usage", "type": "link", "icon": "database", "tooltip": "Session drill-down, prompt analytics"},
    {"title": "Tool Analytics", "url": "/d/claude-code-tools", "type": "link", "icon": "database", "tooltip": "Tool performance, success rates"},
    {"title": "API Performance", "url": "/d/claude-code-api", "type": "link", "icon": "database", "tooltip": "Latency percentiles, errors"}
  ],
  "templating": {
    "list": [
      {
        "name": "organization_id", "label": "Organization", "type": "query",
        "datasource": {"type": "prometheus", "uid": "amp"},
        "query": "label_values(claude_code_session_count_total, organization_id)",
        "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "refresh": 2, "sort": 1
      },
      {
        "name": "user_id", "label": "User", "type": "query",
        "datasource": {"type": "prometheus", "uid": "amp"},
        "query": "label_values(claude_code_session_count_total{organization_id=~\"$organization_id\"}, user_id)",
        "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "refresh": 2, "sort": 1
      },
      {
        "name": "model", "label": "Model", "type": "query",
        "datasource": {"type": "prometheus", "uid": "amp"},
        "query": "label_values(claude_code_cost_usage_USD_total, model)",
        "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "refresh": 2, "sort": 1
      },
      {
        "name": "team", "label": "Team (Athena)", "type": "query",
        "datasource": {"type": "grafana-athena-datasource", "uid": "athena"},
        "query": "SELECT DISTINCT team_id FROM claude_code_telemetry.events WHERE team_id IS NOT NULL AND \"timestamp\" BETWEEN from_iso8601_timestamp('${__from:date:iso}') AND from_iso8601_timestamp('${__to:date:iso}') ORDER BY team_id",
        "includeAll": true, "allValue": "%", "current": {"text": "All", "value": "$__all"}, "refresh": 2
      },
      {
        "name": "user", "label": "User (Athena)", "type": "query",
        "datasource": {"type": "grafana-athena-datasource", "uid": "athena"},
        "query": "SELECT DISTINCT COALESCE(user_name, user_id) AS user_display FROM claude_code_telemetry.events WHERE user_id IS NOT NULL AND \"timestamp\" BETWEEN from_iso8601_timestamp('${__from:date:iso}') AND from_iso8601_timestamp('${__to:date:iso}') ORDER BY user_display",
        "includeAll": true, "allValue": "%", "current": {"text": "All", "value": "$__all"}, "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 100, "type": "row", "title": "KPIs",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false, "panels": []
    },
    {
      "id": 2, "type": "stat", "title": "Total Cost",
      "description": "Cumulative cost across all models in selected time range",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 1},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum(increase(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\"}[$__range]))", "legendFormat": "Cost", "instant": true}],
      "fieldConfig": {"defaults": {"displayName": "Total Cost", "color": {"mode": "fixed", "fixedColor": "#2C3E80"}, "unit": "currencyUSD"}},
      "options": {"colorMode": "background_solid", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4, "type": "stat", "title": "Lines Changed",
      "description": "Total lines of code added and removed",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 1},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum(increase(claude_code_lines_of_code_count_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\"}[$__range]))", "legendFormat": "Lines", "instant": true}],
      "fieldConfig": {"defaults": {"displayName": "Lines Changed", "color": {"mode": "fixed", "fixedColor": "#1A9C8E"}, "unit": "short", "decimals": 0}},
      "options": {"colorMode": "background_solid", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 20, "type": "stat", "title": "Error Rate",
      "description": "Percentage of API requests that resulted in errors",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 1},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum(increase(claude_code_event_count_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", event_type=\"api_error\"}[$__range])) / sum(increase(claude_code_event_count_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", event_type=\"api_request\"}[$__range])) * 100 OR vector(0)", "legendFormat": "Error Rate", "instant": true}],
      "fieldConfig": {"defaults": {"displayName": "Error Rate", "color": {"mode": "thresholds"}, "unit": "percent", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 15}]}}},
      "options": {"colorMode": "background_solid", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 3, "type": "stat", "title": "Total Tokens",
      "description": "Sum of all token types (input, output, cache read, cache creation)",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 5},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum(increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\"}[$__range]))", "legendFormat": "Tokens", "instant": true}],
      "fieldConfig": {"defaults": {"displayName": "Total Tokens", "color": {"mode": "fixed", "fixedColor": "#E25D33"}, "unit": "short", "decimals": 0}},
      "options": {"colorMode": "background_solid", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 30, "type": "stat", "title": "Input Tokens",
      "description": "Total input tokens consumed",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 5},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum(increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\", type=\"input\"}[$__range]))", "instant": true}],
      "fieldConfig": {"defaults": {"displayName": "Input", "color": {"mode": "fixed", "fixedColor": "#5470C6"}, "unit": "short", "decimals": 0}},
      "options": {"colorMode": "background_solid", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 31, "type": "stat", "title": "Output Tokens",
      "description": "Total output tokens generated",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 5},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum(increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\", type=\"output\"}[$__range]))", "instant": true}],
      "fieldConfig": {"defaults": {"displayName": "Output", "color": {"mode": "fixed", "fixedColor": "#9B59B6"}, "unit": "short", "decimals": 0}},
      "options": {"colorMode": "background_solid", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 32, "type": "stat", "title": "Cache Tokens",
      "description": "Total cache tokens (cache read + cache creation)",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 5},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum(increase(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\", type=~\"cacheRead|cacheCreation\"}[$__range]))", "instant": true}],
      "fieldConfig": {"defaults": {"displayName": "Cache", "color": {"mode": "fixed", "fixedColor": "#D4A017"}, "unit": "short", "decimals": 0}},
      "options": {"colorMode": "background_solid", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },

    {
      "id": 101, "type": "row", "title": "Cost by Model",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}, "collapsed": false, "panels": []
    },
    {
      "id": 5, "type": "timeseries",
      "title": "Cost per Minute by Model",
      "description": "Per-model cost accumulated per minute. Based on 60s metric export interval.",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 10},
      "targets": [
        {
          "refId": "A", "datasource": {"type": "prometheus", "uid": "amp"},
          "expr": "sum by (model) (rate(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\"}[2m]) * 60)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 0, "lineWidth": 2, "stacking": {"mode": "none"},
            "lineInterpolation": "smooth", "showPoints": "never", "spanNulls": true,
            "axisLabel": "USD/min"
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": []},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },

    {
      "id": 102, "type": "row", "title": "Token by Model",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22}, "collapsed": false, "panels": []
    },
    {
      "id": 8, "type": "timeseries",
      "title": "Tokens per Minute by Model",
      "description": "Per-model token consumption accumulated per minute. Based on 60s metric export interval.",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 23},
      "targets": [
        {
          "refId": "A", "datasource": {"type": "prometheus", "uid": "amp"},
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\"}[2m]) * 60)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 0, "lineWidth": 2, "stacking": {"mode": "none"},
            "lineInterpolation": "smooth", "showPoints": "never", "spanNulls": true,
            "axisLabel": "tokens/min"
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },

    {
      "id": 105, "type": "row", "title": "Token Details",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35}, "collapsed": false, "panels": []
    },
    {
      "id": 23, "type": "timeseries",
      "title": "Token I/O (Input & Output)",
      "description": "Input and output token rate. Stacked area showing I/O balance.",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "targets": [
        {
          "refId": "A", "datasource": {"type": "prometheus", "uid": "amp"},
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\", type=~\"input|output\"}[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"fillOpacity": 20, "lineWidth": 2, "stacking": {"mode": "normal"}, "gradientMode": "scheme", "axisLabel": "tokens/sec", "showPoints": "never", "spanNulls": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "input"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "output"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 24, "type": "timeseries",
      "title": "Cache Token Usage (Read & Write)",
      "description": "Cache read and creation token rate. High cache reads indicate effective prompt caching and reduce cost.",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "targets": [
        {
          "refId": "A", "datasource": {"type": "prometheus", "uid": "amp"},
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\", type=~\"cacheRead|cacheCreation\"}[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"fillOpacity": 15, "lineWidth": 2, "stacking": {"mode": "normal"}, "gradientMode": "scheme", "axisLabel": "tokens/sec", "showPoints": "never", "spanNulls": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "cacheRead"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "super-light-green"}}, {"id": "displayName", "value": "Cache Read"}]},
          {"matcher": {"id": "byName", "options": "cacheCreation"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}, {"id": "displayName", "value": "Cache Write"}]}
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },

    {
      "id": 103, "type": "row", "title": "Activity",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 44}, "collapsed": false, "panels": []
    },
    {
      "id": 7, "type": "timeseries",
      "title": "Lines of Code (Added vs Removed)",
      "description": "Rate of lines added and removed over 5-minute windows",
      "datasource": {"type": "prometheus", "uid": "amp"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 45},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "amp"}, "expr": "sum by (type) (rate(claude_code_lines_of_code_count_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\"}[5m]))", "legendFormat": "{{type}}"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme", "axisLabel": "lines/sec", "showPoints": "never", "spanNulls": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "added"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "removed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Hourly Event Flow",
      "description": "Event counts by type per hour",
      "datasource": {"type": "grafana-athena-datasource", "uid": "athena"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 45},
      "targets": [{"datasource": {"type": "grafana-athena-datasource", "uid": "athena"}, "rawSQL": "SELECT date_trunc('hour', \"timestamp\") AS time, COUNT(CASE WHEN event_name = 'claude_code.user_prompt' THEN 1 END) AS prompts, COUNT(CASE WHEN event_name = 'claude_code.api_request' THEN 1 END) AS api_calls, COUNT(CASE WHEN event_name = 'claude_code.tool_result' THEN 1 END) AS tool_uses, COUNT(CASE WHEN event_name = 'claude_code.api_error' THEN 1 END) AS errors FROM claude_code_telemetry.events WHERE \"timestamp\" BETWEEN from_iso8601_timestamp('${__from:date:iso}') AND from_iso8601_timestamp('${__to:date:iso}') AND (team_id LIKE '${team}' OR '${team}' = '%') AND (COALESCE(user_name, user_id) LIKE '${user}' OR '${user}' = '%') GROUP BY 1 ORDER BY 1", "format": 1, "connectionArgs": {"region": "__default", "catalog": "__default", "database": "__default", "resultReuseEnabled": false, "resultReuseMaxAgeInMinutes": 60}, "refId": "A"}],
      "fieldConfig": {
        "defaults": {"custom": {"fillOpacity": 15, "lineWidth": 2, "gradientMode": "scheme", "axisLabel": "events/hr", "showPoints": "never", "spanNulls": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "prompts"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "api_calls"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "tool_uses"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "errors"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 52, "type": "table",
      "title": "Top Users by Cost",
      "description": "Per-user metrics from Prometheus (stable, no fluctuation) with user name lookup from Athena",
      "datasource": {"type": "datasource", "uid": "-- Mixed --"},
      "gridPos": {"h": 8, "w": 14, "x": 0, "y": 53},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "grafana-athena-datasource", "uid": "athena"},
          "rawSQL": "SELECT user_id, COALESCE(MAX(user_name), user_id) AS user_name, CAST(COUNT(DISTINCT session_id) AS INTEGER) AS sessions, CAST(COUNT(CASE WHEN event_name = 'claude_code.api_request' THEN 1 END) AS INTEGER) AS api_calls, SUM(CASE WHEN event_name = 'claude_code.api_request' THEN input_tokens + output_tokens + COALESCE(cache_read_tokens, 0) + COALESCE(cache_creation_tokens, 0) ELSE 0 END) AS total_tokens FROM claude_code_telemetry.events WHERE \"timestamp\" BETWEEN from_iso8601_timestamp('${__from:date:iso}') AND from_iso8601_timestamp('${__to:date:iso}') AND (team_id LIKE '${team}' OR '${team}' = '%') GROUP BY user_id",
          "format": 1,
          "connectionArgs": {"region": "__default", "catalog": "__default", "database": "__default", "resultReuseEnabled": false, "resultReuseMaxAgeInMinutes": 60}
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "amp"},
          "expr": "sum by (user_id) (increase(claude_code_cost_usage_USD_total{organization_id=~\"$organization_id\", user_id=~\"$user_id\", model=~\"$model\"}[$__range]))",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "user_id",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "user_id": true,
              "Time": true
            },
            "renameByName": {
              "Value": "total_cost_usd"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "user_name"}, "properties": [{"id": "displayName", "value": "User"}, {"id": "custom.width", "value": 150}]},
          {"matcher": {"id": "byName", "options": "sessions"}, "properties": [{"id": "displayName", "value": "Sessions"}, {"id": "decimals", "value": 0}]},
          {"matcher": {"id": "byName", "options": "api_calls"}, "properties": [{"id": "displayName", "value": "API Calls"}, {"id": "decimals", "value": 0}]},
          {"matcher": {"id": "byName", "options": "total_cost_usd"}, "properties": [{"id": "displayName", "value": "Total Cost"}, {"id": "unit", "value": "currencyUSD"}, {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "transparent", "value": null}, {"color": "#FFF9C4", "value": 1}, {"color": "#FFCDD2", "value": 10}]}}]},
          {"matcher": {"id": "byName", "options": "total_tokens"}, "properties": [{"id": "displayName", "value": "Total Tokens"}, {"id": "unit", "value": "short"}, {"id": "decimals", "value": 0}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"enablePagination": true}, "sortBy": [{"displayName": "Total Cost", "desc": true}], "filterable": true}
    },
    {
      "id": 11, "type": "barchart",
      "title": "Top 10 Tools",
      "description": "Most frequently used tools with success/failure breakdown",
      "datasource": {"type": "grafana-athena-datasource", "uid": "athena"},
      "gridPos": {"h": 8, "w": 10, "x": 14, "y": 53},
