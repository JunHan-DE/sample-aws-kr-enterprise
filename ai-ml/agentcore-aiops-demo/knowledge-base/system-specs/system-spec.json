{
  "system_name": "AIOps Demo Platform - Sample Application",
  "architecture": "3-tier web application",
  "region": "ap-northeast-2",
  "components": {
    "load_balancer": {
      "type": "ALB",
      "scheme": "internet-facing",
      "listeners": [{"port": 80, "protocol": "HTTP"}],
      "health_check": {"path": "/health", "interval_seconds": 30}
    },
    "compute": {
      "type": "EC2 Auto Scaling Group",
      "instance_type": "t3.micro",
      "min_size": 2,
      "max_size": 2,
      "application": "Flask (Python) health check API"
    },
    "database": {
      "type": "RDS PostgreSQL",
      "instance_class": "db.t3.micro",
      "multi_az": false,
      "port": 5432
    }
  },
  "network": {
    "vpc_cidr": "10.0.0.0/16",
    "public_subnets": ["ALB"],
    "private_subnets": ["EC2", "RDS"],
    "nat_gateways": 1
  },
  "monitoring": {
    "alarms": [
      {"name": "aiops-demo-alb-unhealthy", "metric": "UnHealthyHostCount", "threshold": 1},
      {"name": "aiops-demo-alb-5xx", "metric": "HTTPCode_Target_5XX_Count", "threshold": 5},
      {"name": "aiops-demo-ec2-status", "metric": "StatusCheckFailed", "threshold": 1},
      {"name": "aiops-demo-rds-conn", "metric": "DatabaseConnections", "threshold": 0, "comparison": "LessThanOrEqualToThreshold"}
    ]
  }
}
